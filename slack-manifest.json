{
  "display_information": {
    "name": "Screenshot KB",
    "description": "Drop a screenshot, get instant OCR, analysis, and summary powered by Claude Vision.",
    "background_color": "#1a1a1a"
  },
  "features": {
    "bot_user": {
      "display_name": "Screenshot KB",
      "always_online": true
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "chat:write",
        "reactions:write",
        "reactions:read",
        "files:read",
        "channels:history",
        "groups:history"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "request_url": "https://kb.dalyandco.com/api/slack/events",
      "bot_events": [
        "message.channels",
        "message.groups"
      ]
    },
    "interactivity": {
      "is_enabled": false
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": false,
    "token_rotation_enabled": false
  }
}
